<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDDDE6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <!-- ===== HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="20dp">

            <!-- Bear icon circle -->
            <TextView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text="🐻"
                android:textSize="38sp"
                android:gravity="center"
                android:background="@drawable/bear_circle_bg"
                android:layout_marginBottom="10dp"/>

            <!-- App title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEDDY WIFI AUTH"
                android:textColor="#C06080"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.05"
                android:paddingBottom="4dp"/>

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Created By - Aung Htet Phyo[NamtTaw]"
                android:textColor="#C09AB0"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingBottom="2dp"/>

            <!-- Modby italic -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modby"
                android:textColor="#D4A8BB"
                android:textSize="11sp"
                android:textStyle="italic"
                android:gravity="center"
                android:paddingBottom="12dp"/>

            <!-- Buy Key Button -->
            <Button
                android:id="@+id/btn_buy_key"
                android:layout_width="160dp"
                android:layout_height="42dp"
                android:background="@drawable/btn_buy_key_bg"
                android:text="🛒  Buy Key"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- ===== CARD: SYS_CONFIG ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐾"
                    android:textSize="18sp"
                    android:paddingEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SYS_CONFIG"
                    android:textColor="#C06080"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>
            </LinearLayout>

            <!-- Gateway IP label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GATEWAY IP ADDRESS"
                android:textColor="#A0768A"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:paddingBottom="6dp"/>

            <!-- IP EditText -->
            <EditText
                android:id="@+id/et_ip"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_bg"
                android:hint="192.168.110.1"
                android:textColorHint="@color/text_hint"
                android:inputType="textNoSuggestions"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="14dp"/>

            <!-- Encrypted session label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENCRYPTED SESSION (BASE64 AES)"
                android:textColor="#A0768A"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:paddingBottom="6dp"/>

            <!-- Encrypted URL EditText -->
            <EditText
                android:id="@+id/et_enc_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="72dp"
                android:background="@drawable/input_bg"
                android:hint="Share your secret bear codes here...\n(URL or codes)"
                android:textColorHint="@color/text_hint"
                android:inputType="textMultiLine|textNoSuggestions"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:lines="2"
                android:maxLines="4"
                android:scrollbars="vertical"
                android:gravity="top"/>

            <!-- Buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:weightSum="5">

                <Button
                    android:id="@+id/btn_start"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="3"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/btn_start_bg"
                    android:text="▶  START"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btn_stop"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="3"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/btn_stop_bg"
                    android:text="■  STOP"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btn_clear_log"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="2"
                    android:background="@drawable/btn_clear_bg"
                    android:text="CLR"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

            </LinearLayout>
        </LinearLayout>

        <!-- ===== CARD: NETWORK_STATUS ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐻"
                    android:textSize="18sp"
                    android:paddingEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NETWORK_STATUS"
                    android:textColor="#C06080"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐻🐻🐻🐻"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- STATUS row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="STATUS:"
                    android:textColor="#A0768A"
                    android:textSize="13sp"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IDLE"
                    android:textColor="#C06080"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- TOTAL REQUESTS row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TOTAL REQUESTS:"
                    android:textColor="#A0768A"
                    android:textSize="13sp"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tv_request_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#C06080"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- LAST REQUEST row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LAST REQUEST:"
                    android:textColor="#A0768A"
                    android:textSize="13sp"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tv_last_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#C06080"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- SESSION ID row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SESSION ID:"
                    android:textColor="#A0768A"
                    android:textSize="13sp"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tv_session_id"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:text="None"
                    android:textColor="#C06080"
                    android:textSize="12sp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:gravity="end"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ===== CARD: LIVE_LOGS ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=">_  LIVE_LOGS"
                    android:textColor="#C06080"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="•••"
                    android:textColor="#D4A8BB"
                    android:textSize="16sp"
                    android:letterSpacing="0.1"/>
            </LinearLayout>

            <!-- Log list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_logs"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="#FFF0F5"
                android:padding="8dp"
                android:clipToPadding="false"
                android:scrollbars="vertical"/>

            <!-- Sleeping bear watermark (shown only when empty) -->
            <TextView
                android:id="@+id/tv_bear_watermark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🐻"
                android:textSize="48sp"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:visibility="gone"/>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="16dp"/>

    </LinearLayout>
</ScrollView>
